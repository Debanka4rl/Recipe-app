@model supaathrowaway.Models.Recipe

@{
    ViewData["Title"] = Model.Name;
}

<div style="max-width: 800px; margin: 0 auto; padding: 20px;">

    <a href="/Home/home" style="color: #6c757d; text-decoration: none; font-weight: bold;">← Back to Dashboard</a>

    <h1 style="margin-top: 20px; margin-bottom: 5px;">@Model.Name</h1>
    <span style="display: inline-block; background-color: #e9ecef; padding: 5px 10px; border-radius: 20px; font-weight: bold; font-size: 0.9em; margin-bottom: 20px;">
        Complexity: @Model.Complexity
    </span>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 10px;">

        <div>
            @if (!string.IsNullOrEmpty(Model.Picture))
            {
                <img src="@Model.Picture" alt="@Model.Name" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);"
                     onerror="this.onerror=null; this.src='https://placehold.co/600x400?text=Image+Load+Failed';" />
            }
            else
            {
                <div style="width: 100%; height: 300px; background-color: #f1f3f5; display: flex; align-items: center; justify-content: center; border-radius: 8px; color: #6c757d; font-style: italic; border: 1px dashed #dee2e6;">
                    No Image Provided For This Recipe
                </div>
            }
        </div>

        <div>
            <h3>Description</h3>
            <p style="line-height: 1.6; color: #333; white-space: pre-line; margin-bottom: 25px;">@Model.Description</p>

            <div style="margin-top: 30px; border-top: 1px solid #eee; padding-top: 20px;">
                <button id="btnSummary" onclick="triggerAiSummary()" style="background-color: #007bff; color: white; border: none; padding: 10px 16px; border-radius: 4px; font-weight: bold; cursor: pointer;">
                    ✨ Generate AI Summary
                </button>

                <div id="summaryBox" style="display: none; background-color: #f0f7ff; border-left: 4px solid #007bff; padding: 15px; border-radius: 4px; margin-top: 15px;">
                    <h4 style="margin: 0 0 5px 0; color: #0056b3;">✨ AI Insights Summary</h4>
                    <p id="summaryText" style="margin: 0; font-style: italic; color: #444; line-height: 1.5;"></p>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    async function triggerAiSummary() {
        const btn = document.getElementById('btnSummary');
        const box = document.getElementById('summaryBox');
        const txt = document.getElementById('summaryText');

        // Prevent double clicking and show visual state changes
        btn.disabled = true;
        btn.innerText = "Consulting Gemini 3.5...";

        try {
            // Hit the new POST endpoint on your controller
            const response = await fetch('/Home/GetSummary/@Model.Id', { method: 'POST' });
            const data = await response.text();

            // Populate text layout container and reveal it
            txt.innerText = data;
            box.style.display = 'block';
        }
        catch (error) {
            txt.innerText = "Could not reach the AI server right now.";
            box.style.display = 'block';
        }
        finally {
            btn.disabled = false;
            btn.innerText = "Regenerate Summary";
        }
    }
</script>