@model supaathrowaway.Models.Recipe

@{
    ViewData["Title"] = "Add New Recipe";
}

<h2>Add a New Recipe</h2>
<p style="color: gray; font-size: 0.9em;">Fill out the details below to add this recipe directly to Supabase.</p>

@if (ViewBag.ErrorMessage != null)
{
    <div style="color: red; font-weight: bold; margin-bottom: 15px;">@ViewBag.ErrorMessage</div>
}

<div style="max-width: 500px; margin-top: 20px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div style="margin-bottom: 15px;">
            <label asp-for="Name" style="display: block; font-weight: bold; margin-bottom: 5px;">Recipe Name:</label>
            <input asp-for="Name" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" required />
        </div>

        <div style="margin-bottom: 15px;">
            <label asp-for="Complexity" style="display: block; font-weight: bold; margin-bottom: 5px;">Complexity:</label>
            <select asp-for="Complexity" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" required>
                <option value="">-- Select Complexity --</option>
                <option value="Easy">Easy</option>
                <option value="Medium">Medium</option>
                <option value="Hard">Hard</option>
            </select>
        </div>

        <div style="margin-bottom: 15px;">
            <label asp-for="Description" style="display: block; font-weight: bold; margin-bottom: 5px;">Description:</label>
            <textarea asp-for="Description" rows="4" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" required></textarea>
        </div>

        <div style="margin-bottom: 20px;">
            <label asp-for="Picture" style="display: block; font-weight: bold; margin-bottom: 5px;">Picture URL (Optional):</label>
            <input asp-for="Picture" type="url" placeholder="https://example.com/image.jpg" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" />
        </div>

        <div style="display: flex; gap: 10px;">
            <button type="submit" style="background-color: #28a745; color: white; border: none; padding: 10px 20px; border-radius: 4px; font-weight: bold; cursor: pointer;">
                Save Recipe
            </button>
            <a href="/Home/home" style="background-color: #6c757d; color: white; border: none; padding: 10px 20px; border-radius: 4px; font-weight: bold; text-decoration: none; text-align: center;">
                Cancel
            </a>
        </div>
    </form>
</div>